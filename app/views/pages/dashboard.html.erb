
<div class="container mx-1">
  <div class="row">

    <div class="col p-4 my-4">
      <h3>Your Chats:</h3>
      <div class="chat-list-container">
        <% if @chats.any? %>
          <ul>
            <% @chats.each do |chat| %>
              <li><%= chat.title %></li>
            <% end %>
          </ul>
        <% else %>
          There are no chats yet.
        <% end %>
        <%= button_to "New Chat", chats_path, class: 'btn btn-primary' %>
      </div>
    </div>

    <% if @chat %>
      <div class="col-8 p-4 my-4 bg-white">
        <h1 id="chat_title"><%= @chat.title %></h1>
        <div id="messages">
           <%= render "messages/messages", messages: @chat.messages %>
        </div>


        <div id="new_message_container">
          <%= render "messages/form", chat: @chat, message: @message %>
        </div>

      </div>
    <% end %>
  </div>
</div>
