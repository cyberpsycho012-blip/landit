
<div class="container mx-1">
  <div class="row">

    <div class="col p-4 my-4">
      <h3>Your Chats:</h3>
      <div class="chat-list-container">
        <% if @chats.any? %>
          <ul>
            <% @chats.each do |chat| %>
              <li><%= chat.title %></li>
            <% end %>
          </ul>
        <% else %>
          There are no chats yet.
          <%= console %>
        <% end %>
        <%= button_to "New Chat", chats_path, class: 'btn btn-primary' %>
      </div>
    </div>

    <% if @chat %>
    <div class="col-8 p-4 my-4 bg-white">
      <h1 id="chat_title"><%= @chat.title %></h1>
      <div id="messages">
        <% @chat.messages.each do |message| %>
          <% if message.role == "user" %>
            <div class="d-flex justify-content-end mb-2">
              <div class="bg-light-blue px-3 pb-0 pt-3 rounded-pill">
                <%= raw(render_markdown(message.content)) %>
              </div>
            </div>
          <% elsif message.role == "assistant" %>
            <div class="d-flex justify-content-start mb-5">
              <div class="px-3 pb-0 pt-3">
                <%= raw(render_markdown(message.content)) %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>


      <div id="new_message_container">
        <%= simple_form_for [@chat, @message] do |f| %>
          <%= f.input :content, label: false, required: true, placeholder: "How should I adjust my resume?" %>
          <%= f.button :submit, 'Ask', class: 'btn btn-primary float-end' %>
        <% end %>
      </div>
<% end %>
    </div>
  </div>
</div>
